{
  "private": true,
  "type": "module",
  "scripts": {
    "start": "ori serve watch src, =debug src/site.ori",
    "build": "ori copy src/site.ori, clear files:build",
    "diff-with-main": "rm -rf build-old && git checkout main && npm i && npm run build && mv build build-old && git checkout - && npm i && npm run build && npm run ori:changes",
    "deploy": "NODE_ENV=production git pull && npm ci && netlify deploy --build --prod",
    "ori:changes": "ori changes build-old, build",
    "postbuildz": "html-minifier --collapse-whitespace --remove-empty-attributes --remove-comments --remove-optional-tags --remove-redundant-attributes --remove-attribute-quotes --remove-script-type-attributes --remove-tag-whitespace --use-short-doctype --minify-css true --minify-js true build/index.html -o build/index.html"
  },
  "dependencies": {
    "@weborigami/origami": "0.6.14",
    "dotenv": "^16.4.5",
    "marked": "^4.2.12",
    "p-limit": "^5.0.0",
    "tldts": "^7.0.17"
  }
}
