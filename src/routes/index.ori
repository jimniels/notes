(site) => <templates/Page.ori.html>({
  site,
  title: "Jim Nielsen’s Notes",
  children: `${Tree.map(
    Tree.take(site.items, 10),
    (item) => <templates/Note.ori.html>(item)
  )}
  <p style="margin: 4rem 0; font-weight: bold;">
    <a href="/n/">View all ${site.items.length.toLocaleString()} notes</a>
  </p>`,
  path: "/"
})