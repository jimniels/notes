(site) => <templates/Page.ori.html>({
  site,
  title: "Subscribe | Jim Nielsen’s Notes",
  path: "/subscribe/",
  children: `
  <header>
    <h1>Subscribe</h1>
    <p>
      Yes, yes! You know about RSS? You have done well. Come, I have been expecting you.
    </p>
  </header>
  <main>
    <ul>
      <li><a href="/feed.json">JSON Feed</a></li>
      <li><a href="/feed.xml">RSS Feed</a></li>
    </ul>
  </main>
  `
})