(site) => <templates/Page.ori.html>({
  site,
  title: "Search | Jim Nielsen’s Notes",
  children: `
    <header>
      <h1>Search</h1>
      <p>All ${site.items.length.toLocaleString()} notes I’ve ever published are right here. Use your browser’s “Find” functionality to hunt for keywords — that’s my solution for search :)</p>
    </header>
    <main>
    ${Tree.map(
      site.items,
      (item) => <templates/Note.ori.html>(item)
    )}
    </main>
  `
  path: "/n/"
})